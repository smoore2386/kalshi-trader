# WeatherSafeClaw Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it is listed in .gitignore.

# ── Kalshi API credentials (required) ─────────────────────────────────────────
# Your Kalshi API key (UUID format from the Kalshi dashboard)
KALSHI_API_KEY=your-kalshi-api-key-here

# Your RSA private key in PEM format.
# Paste the full PEM block, replacing newlines with \n, OR use the multiline format:
# KALSHI_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----
# MIIEo...
# -----END RSA PRIVATE KEY-----"
KALSHI_PRIVATE_KEY_PEM=

# ── Telegram notifications (optional but strongly recommended) ─────────────────
# Create a bot via @BotFather, then start a chat and get the chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Discord notifications (optional) ──────────────────────────────────────────
# Create a webhook in your Discord server settings
DISCORD_WEBHOOK_URL=

# ── Scheduling ─────────────────────────────────────────────────────────────────
TIMEZONE=America/New_York
